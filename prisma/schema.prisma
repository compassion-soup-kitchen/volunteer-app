generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ─── Auth & Roles ─────────────────────────────────────

enum Role {
  PUBLIC
  VOLUNTEER
  COORDINATOR
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(PUBLIC)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  volunteerProfile     VolunteerProfile?
  reviewedApplications Application[]        @relation("ReviewedBy")
  createdShifts        Shift[]
  markedAttendance     ShiftSignup[]        @relation("AttendanceMarkedBy")
  createdTraining      TrainingSession[]
  createdAnnouncements Announcement[]
  uploadedDocuments    Document[]           @relation("UploadedBy")
  updatedAgreements    AgreementTemplate[]  @relation("AgreementTemplateUpdatedBy")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Volunteer Onboarding ─────────────────────────────

enum VolunteerStatus {
  APPLICATION_SUBMITTED
  AWAITING_VETTING
  APPROVED_FOR_INDUCTION
  ACTIVE
  INACTIVE
}

enum MojStatus {
  NOT_STARTED
  SUBMITTED
  CLEARED
  FLAGGED
}

model VolunteerProfile {
  id                           String          @id @default(cuid())
  userId                       String          @unique
  phone                        String?
  address                      String?
  dateOfBirth                  DateTime?
  emergencyContactName         String?
  emergencyContactPhone        String?
  emergencyContactRelationship String?
  bio                          String?
  availability                 Json?
  skills                       String[]
  status                       VolunteerStatus @default(APPLICATION_SUBMITTED)
  mojStatus                    MojStatus       @default(NOT_STARTED)
  createdAt                    DateTime        @default(now())
  updatedAt                    DateTime        @updatedAt

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  interests           ServiceArea[]        @relation("VolunteerInterests")
  applications        Application[]
  documents           Document[]
  signedAgreements    SignedAgreement[]
  shiftSignups        ShiftSignup[]
  trainingAttendances TrainingAttendance[]
}

enum ApplicationStatus {
  PENDING
  APPROVED
  DECLINED
  INFO_REQUESTED
}

model Application {
  id           String            @id @default(cuid())
  volunteerId  String
  status       ApplicationStatus @default(PENDING)
  notes        String?
  submittedAt  DateTime          @default(now())
  reviewedAt   DateTime?
  reviewedById String?

  volunteer  VolunteerProfile @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  reviewedBy User?            @relation("ReviewedBy", fields: [reviewedById], references: [id])
}

enum DocumentType {
  ID
  MOJ_FORM
  SIGNED_AGREEMENT
  POLICY
  TRAINING_MATERIAL
}

model Document {
  id           String       @id @default(cuid())
  volunteerId  String?
  type         DocumentType
  fileName     String
  fileUrl      String
  uploadedAt   DateTime     @default(now())
  uploadedById String?

  volunteer  VolunteerProfile? @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  uploadedBy User?             @relation("UploadedBy", fields: [uploadedById], references: [id])
}

enum AgreementType {
  CODE_OF_CONDUCT
  SAFEGUARDING
  VOLUNTEER_APPLICATION
  POLICIES
}

model SignedAgreement {
  id              String        @id @default(cuid())
  volunteerId     String
  agreementType   AgreementType
  signatureData   String        @db.Text
  signedAt        DateTime      @default(now())
  documentVersion String?

  volunteer VolunteerProfile @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
}

model AgreementTemplate {
  id            String        @id @default(cuid())
  agreementType AgreementType @unique
  title         String
  content       String        @db.Text
  version       String        @default("1.0")
  updatedAt     DateTime      @updatedAt
  updatedById   String?

  updatedBy User? @relation("AgreementTemplateUpdatedBy", fields: [updatedById], references: [id])
}

// ─── Operations ───────────────────────────────────────

model ServiceArea {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())

  shifts     Shift[]
  volunteers VolunteerProfile[] @relation("VolunteerInterests")
}

model Shift {
  id            String   @id @default(cuid())
  serviceAreaId String
  date          DateTime @db.Date
  startTime     String
  endTime       String
  capacity      Int
  notes         String?
  createdById   String
  createdAt     DateTime @default(now())

  serviceArea ServiceArea   @relation(fields: [serviceAreaId], references: [id])
  createdBy   User          @relation(fields: [createdById], references: [id])
  signups     ShiftSignup[]
}

enum SignupStatus {
  SIGNED_UP
  ATTENDED
  NO_SHOW
  CANCELLED
}

model ShiftSignup {
  id                   String       @id @default(cuid())
  shiftId              String
  volunteerId          String
  status               SignupStatus @default(SIGNED_UP)
  signedUpAt           DateTime     @default(now())
  attendanceMarkedById String?
  attendanceMarkedAt   DateTime?

  shift              Shift            @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  volunteer          VolunteerProfile @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  attendanceMarkedBy User?            @relation("AttendanceMarkedBy", fields: [attendanceMarkedById], references: [id])

  @@unique([shiftId, volunteerId])
}

enum TrainingType {
  INDUCTION
  DE_ESCALATION
  HEALTH_SAFETY
  OTHER
}

model TrainingSession {
  id          String       @id @default(cuid())
  type        TrainingType
  title       String
  description String?
  date        DateTime     @db.Date
  startTime   String
  endTime     String
  capacity    Int
  location    String?
  createdById String
  createdAt   DateTime     @default(now())

  createdBy   User                 @relation(fields: [createdById], references: [id])
  attendances TrainingAttendance[]
}

enum AttendanceStatus {
  REGISTERED
  ATTENDED
  NO_SHOW
  CANCELLED
}

model TrainingAttendance {
  id          String           @id @default(cuid())
  sessionId   String
  volunteerId String
  status      AttendanceStatus @default(REGISTERED)

  session   TrainingSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  volunteer VolunteerProfile @relation(fields: [volunteerId], references: [id], onDelete: Cascade)

  @@unique([sessionId, volunteerId])
}

// ─── Communication ────────────────────────────────────

enum Audience {
  ALL
  VOLUNTEERS
  COORDINATORS
}

model Announcement {
  id          String    @id @default(cuid())
  title       String
  body        String    @db.Text
  audience    Audience  @default(ALL)
  createdById String
  createdAt   DateTime  @default(now())
  sentAt      DateTime?

  createdBy User @relation(fields: [createdById], references: [id])
}
